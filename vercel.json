{
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm --filter db exec prisma generate && pnpm --filter api build",
  "functions": {
    "apps/api/api/index.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/(.*)", "destination": "/apps/api/api/index.ts" }
  ]
}
