rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Admin: checked via the admins collection (populated via Firebase Console
    // or the setAdminUser Cloud Function).
    function isAdmin() {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // Prevent clients from writing protected fields on their own profile
    function noProtectedFieldChanges() {
      return !('subscription' in request.resource.data.diff(resource.data).affectedKeys()) &&
             !('isAdmin'      in request.resource.data.diff(resource.data).affectedKeys());
    }

    // ── Public content ────────────────────────────────────────────────────────
    // All content collections are publicly readable — the app filters by
    // published==true at query time. Content is not sensitive.
    // Writes require admin role (enforced server-side via admin SDK for seeding,
    // and via isAdmin() for the admin panel).

    match /articles/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /opportunities/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /products/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /programmes/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /toolbox/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) && noProtectedFieldChanges();
    }

    // ── Admins ────────────────────────────────────────────────────────────────

    match /admins/{uid} {
      allow read:  if isSignedIn() && request.auth.uid == uid;
      allow write: if false; // set only via Firebase Console or admin SDK
    }

    // ── Orders ────────────────────────────────────────────────────────────────

    match /orders/{id} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow read, write: if isAdmin();
      allow update, delete: if false;
    }

    // ── Team & Stories ────────────────────────────────────────────────────────

    match /team/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    match /stories/{id} {
      allow read:  if true;
      allow write: if isAdmin();
    }
  }
}
